# Spring Boot Application Config
SERVER_PORT=8080

# Database Config
MONGODB_URI=mongodb://localhost:27017/cosmetics_db

# Email Config
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# JWT Security
# Remember to generate a strong 256-bit hex key for JWT_SECRET in production!
JWT_SECRET=YOUR_VERY_SECURE_JWT_SECRET_KEY_CHANGE_ME_PLEASE
JWT_EXPIRATION=86400000

# Cloudinary (Used for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
